// Kira Initiative — Prisma schema
// Two role-domains in one DB: anonymous patient sessions + authenticated doctor portal.
// Patient PII is captured ONLY at escalation; AI transcripts are NEVER shared with doctors.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ANONYMOUS PATIENT SESSIONS
// ─────────────────────────────────────────

model AnonymousSession {
  id              String    @id @default(uuid())
  sessionToken    String    @unique
  language        String    @default("en")
  currentTopic    String?
  isSexualHealth  Boolean   @default(false)
  scanLocked      Boolean   @default(false)
  severityLevel   String    @default("green")
  offenceCount    Int       @default(0)
  messages        Message[]
  scans           ScanImage[]
  escalation      Escalation?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime

  @@index([expiresAt])
}

model Message {
  id          String           @id @default(uuid())
  sessionId   String
  session     AnonymousSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String
  content     String
  scanImageId String?
  scanResult  String?
  careBadge   String?
  createdAt   DateTime         @default(now())

  @@index([sessionId, createdAt])
}

model ScanImage {
  id             String           @id @default(uuid())
  sessionId      String
  session        AnonymousSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  filePath       String?
  bodyArea       String
  approved       Boolean          @default(false)
  claudeAnalysis String?
  severity       String?
  createdAt      DateTime         @default(now())
}

// ─────────────────────────────────────────
// ESCALATION — anonymity ends here, minimal PII captured
// ─────────────────────────────────────────

model Escalation {
  id                   String           @id @default(uuid())
  sessionId            String           @unique
  session              AnonymousSession @relation(fields: [sessionId], references: [id])
  patientName          String
  patientAge           Int
  patientPhone         String
  patientEmail         String?
  hospitalId           String
  hospital             Hospital         @relation(fields: [hospitalId], references: [id])
  symptomSummary       String
  escalationReason     String
  severityAtEscalation String
  status               String           @default("pending")
  assignedDoctorId     String?
  doctor               Doctor?          @relation(fields: [assignedDoctorId], references: [id])
  consultation         Consultation?
  appointment          Appointment?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([status, severityAtEscalation])
  @@index([assignedDoctorId])
}

// ─────────────────────────────────────────
// DOCTORS
// ─────────────────────────────────────────

model Doctor {
  id                 String         @id @default(uuid())
  email              String         @unique
  passwordHash       String
  fullName           String
  medicalLicenseId   String         @unique
  specialty          String
  department         String
  hospitalId         String
  hospital           Hospital       @relation(fields: [hospitalId], references: [id])
  licenseFilePath    String?
  profilePhoto       String?
  verificationStatus String         @default("pending")
  verificationNote   String?
  isOnline           Boolean        @default(false)
  twoFAEnabled       Boolean        @default(false)
  twoFASecret        String?
  role               String         @default("doctor") // "doctor" | "admin"
  escalations        Escalation[]
  consultations      Consultation[]
  appointments       Appointment[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([hospitalId])
  @@index([verificationStatus])
}

// ─────────────────────────────────────────
// CONSULTATIONS (real-time chat between doctor and identified patient)
// ─────────────────────────────────────────

model Consultation {
  id              String           @id @default(uuid())
  escalationId    String           @unique
  escalation      Escalation       @relation(fields: [escalationId], references: [id])
  doctorId        String
  doctor          Doctor           @relation(fields: [doctorId], references: [id])
  status          String           @default("active")
  riskLevel       String?
  consultMessages ConsultMessage[]
  internalNotes   InternalNote[]
  soapNote        SoapNote?
  prescription    Prescription?
  followUpDate    DateTime?
  recommendation  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([doctorId, status])
}

model ConsultMessage {
  id             String       @id @default(uuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  senderRole     String
  content        String
  fileUrl        String?
  seenByPatient  Boolean      @default(false)
  seenByDoctor   Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([consultationId, createdAt])
}

model InternalNote {
  id             String       @id @default(uuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  content        String
  createdAt      DateTime     @default(now())

  @@index([consultationId])
}

model SoapNote {
  id             String       @id @default(uuid())
  consultationId String       @unique
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  subjective     String
  objective      String
  assessment     String
  plan           String
  finalized      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Prescription {
  id             String       @id @default(uuid())
  consultationId String       @unique
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  filePath       String
  notes          String?
  createdAt      DateTime     @default(now())
}

// ─────────────────────────────────────────
// APPOINTMENTS
// ─────────────────────────────────────────

model Appointment {
  id           String     @id @default(uuid())
  escalationId String     @unique
  escalation   Escalation @relation(fields: [escalationId], references: [id])
  doctorId     String
  doctor       Doctor     @relation(fields: [doctorId], references: [id])
  hospitalId   String
  hospital     Hospital   @relation(fields: [hospitalId], references: [id])
  scheduledAt  DateTime
  type         String
  status       String     @default("scheduled")
  notes        String?
  createdAt    DateTime   @default(now())

  @@index([doctorId, scheduledAt])
}

// ─────────────────────────────────────────
// HOSPITALS
// ─────────────────────────────────────────

model Hospital {
  id            String        @id @default(uuid())
  name          String
  fullName      String
  address       String
  helpdeskPhone String
  type          String
  menHealth     Boolean       @default(true)
  departments   String[]
  doctors       Doctor[]
  escalations   Escalation[]
  appointments  Appointment[]
}

// ─────────────────────────────────────────
// OTHERS HAVE ASKED FEED
// ─────────────────────────────────────────

model OthersAskedEntry {
  id        String   @id @default(uuid())
  question  String
  aiAnswer  String
  topic     String
  careBadge String
  createdAt DateTime @default(now())

  @@index([topic, createdAt])
}

// ─────────────────────────────────────────
// SECURITY LOGS
// ─────────────────────────────────────────

model SecurityLog {
  id        String   @id @default(uuid())
  doctorId  String?
  event     String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([doctorId])
}

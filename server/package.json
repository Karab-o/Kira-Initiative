{
  "name": "@kira/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../.env -o -- node --watch index.js",
    "start": "node index.js",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "db:reset": "dotenv -e ../.env -- prisma migrate reset --force",
    "db:seed": "node --env-file=../.env prisma/seed.js",
    "db:studio": "dotenv -e ../.env -- prisma studio",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:validate": "dotenv -e ../.env -- prisma validate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "groq-sdk": "^0.7.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.106.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^10.3.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0"
  }
}

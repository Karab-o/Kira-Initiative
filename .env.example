# ─── Kira Initiative — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in all values before running.
# NEVER commit your real .env to version control.

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Neon, Supabase, Railway Postgres, or any standard PostgreSQL URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret (min 64 chars) in Node:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER use the placeholder below in production.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_64_CHARS
SESSION_SECRET=REPLACE_WITH_ANOTHER_STRONG_RANDOM_SECRET

# ── Anthropic AI ──────────────────────────────────────────────────────────────
# Get your API key from: https://console.anthropic.com/settings/api-keys
# Ensure the workspace has a positive credit balance:
#   https://console.anthropic.com/settings/billing
# Enable auto-recharge so the AI never goes down mid-deployment.
ANTHROPIC_API_KEY=sk-ant-api03-replace-me

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
UPLOAD_DIR=./uploads

# ── CORS & Frontend ───────────────────────────────────────────────────────────
# Set to your deployed frontend URL — no trailing slash.
# Example: https://kira.yourdomain.com
FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN

# ── Session & Rate Limiting ───────────────────────────────────────────────────
SESSION_TTL_HOURS=24
AI_RATE_LIMIT_PER_HOUR=30

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND BUILD NOTE (Vite)
# ─────────────────────────────────────────────────────────────────────────────
# For same-domain deploys (frontend served by the same host as the API) the
# default baseURL of "/api" in client/src/lib/api.js works without any change.
#
# For separate-domain deploys, set this in your CI/CD build environment:
#   VITE_API_URL=https://api.yourdomain.com/api
